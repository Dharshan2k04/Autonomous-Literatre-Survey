# Copy this file to .env and fill in your actual values
# NEVER commit .env to source control

# -----------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-large

# -----------------------------------------------------------------------
# Pinecone
# -----------------------------------------------------------------------
PINECONE_API_KEY=pcsk_...
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=literature-survey

# -----------------------------------------------------------------------
# PostgreSQL (local dev — docker-compose fills this automatically)
# -----------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/literature_survey

# -----------------------------------------------------------------------
# Redis (local dev)
# -----------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------
# Semantic Scholar (optional – increases rate limits)
# -----------------------------------------------------------------------
SEMANTIC_SCHOLAR_API_KEY=

# -----------------------------------------------------------------------
# App
# -----------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
