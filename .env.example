# ============================================
# Autonomous Literature Survey - Environment
# ============================================
# Copy this file to .env and fill in values

# ---- Application ----
APP_NAME=autonomous-literature-survey
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ---- Database ----
# Option A: set individual parts (DATABASE_URL is computed automatically)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=litsurvey
POSTGRES_PASSWORD=litsurvey_dev
POSTGRES_DB=litsurvey
# Option B: set a full URL directly (overrides POSTGRES_* above)
# DATABASE_URL=postgresql+asyncpg://litsurvey:litsurvey_dev@localhost:5432/litsurvey

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- OpenAI ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=1536

# ---- Anthropic ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ---- LLM Provider (openai | anthropic) ----
LLM_PROVIDER=openai

# ---- Pinecone ----
PINECONE_API_KEY=
PINECONE_INDEX_NAME=literature-survey
PINECONE_ENVIRONMENT=us-east-1

# ---- OAuth (Google) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ---- OAuth (GitHub) ----
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback

# ---- External APIs ----
SEMANTIC_SCHOLAR_API_KEY=
CROSSREF_EMAIL=your-email@example.com

# ---- JWT ----
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=json

# ---- AWS (for production) ----
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
ECR_REGISTRY=
